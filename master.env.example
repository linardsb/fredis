# =============================================================================
# Master Environment File — All variables for the Fredis workspace
# =============================================================================
# Copy to master.env and fill in your values.
# Run: python setup_workspace.py --env master.env
# Variables with defaults (models, config) are auto-filled if omitted.

# === Shared / Multi-Repo Keys ===
# OpenAI (video-processor transcription + obsidian-agent embeddings)
OPENAI_API_KEY=
# Anthropic (obsidian-agent LLM)
ANTHROPIC_API_KEY=
# GitHub PAT (content-engine rate limit)
GITHUB_TOKEN=

# === Content Engine ===
# PostgreSQL connection (e.g. postgresql://user:pass@host:6543/db)
CE_DATABASE_URL=
# Brave Search API key for content-engine
CE_BRAVE_API_KEY=
# OpenRouter API key
OPENROUTER_API_KEY=
# Supadata API key (YouTube transcripts)
SUPADATA_API_KEY=
# Perplexity API key
PERPLEXITY_API_KEY=
# Reddit app client ID
REDDIT_CLIENT_ID=
# Reddit app client secret
REDDIT_CLIENT_SECRET=

# === Video Processor ===
# Google Gemini API key
GEMINI_API_KEY=
# Replicate API token (face swap)
REPLICATE_API_TOKEN=

# === Obsidian AI Agent ===
# PostgreSQL+asyncpg connection for obsidian-agent
OA_DATABASE_URL=
# Brave Search API key for obsidian-agent
OA_BRAVE_API_KEY=
# Absolute path to Obsidian vault
OBSIDIAN_VAULT_PATH=
# Supabase project URL
SUPABASE_PROJECT_URL=
# Supabase anon/service key
SUPABASE_KEY=
# Supabase URL (for RAG)
SUPABASE_URL=
# Supabase service role key (for RAG)
SUPABASE_SERVICE_KEY=
# Embedding API key (usually same as OPENAI_API_KEY)
EMBEDDING_API_KEY=

# === Second Brain (Heartbeat & Scripts) ===
# Your name — used in prompts and notifications
OWNER_NAME=
# PostgreSQL connection (leave empty for local SQLite)
SB_DATABASE_URL=
# Asana Personal Access Token
ASANA_ACCESS_TOKEN=
# Asana Workspace and Project IDs
ASANA_WORKSPACE_ID=
ASANA_PROJECT_ID=
# Asana user mapping — friendly name to GID (format: name:gid,name:gid)
ASANA_USERS=
# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=
# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# Your Slack user ID (for mention detection)
SLACK_OWNER_USER_ID=
# Google Calendar ID (usually your email)
GOOGLE_CALENDAR_ID=
# Monday.com API v2 token + user ID + board mapping (Name:ID pairs, comma-separated)
MONDAY_API_TOKEN=
MONDAY_USER_ID=
MONDAY_BOARD_IDS=
# GitHub username (PAT is reused from the shared GITHUB_TOKEN at the top)
GITHUB_USERNAME=

# === Optional Overrides (defaults used if omitted) ===
# ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8123","app://obsidian.md","capacitor://localhost"]
# ANALYSIS_MODEL=openrouter:anthropic/claude-sonnet-4.5
# API_PREFIX=/api
# APP_NAME=Obsidian Agent Project
# ASANA_WORKSPACE_ID=
# ASANA_PROJECT_ID=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL_CHOICE=text-embedding-3-small
# ENABLE_RAG=true
# ENVIRONMENT=development
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_THUMBNAIL_MODEL=gemini-3-pro-image-preview
# GOOGLE_CALENDAR_ID=
# HEARTBEAT_ACTIVE_HOURS_END=20:00
# HEARTBEAT_ACTIVE_HOURS_START=05:00
# HEARTBEAT_INTERVAL_MINUTES=120
# HEARTBEAT_TIMEZONE=Europe/London
# LLM_MODEL=claude-haiku-4-5
# LOG_LEVEL=INFO
# RAG_PIPELINE_ID=obsidian-vault-rag
# SLACK_MONITORED_CHANNELS=second-brain
# DRAFT_EXPIRY_HOURS=24
# EXPIRED_DRAFT_RETENTION_DAYS=7
# SLACK_NOTIFICATION_CHANNEL="#second-brain"
# SYNTHESIS_MODEL=openrouter:anthropic/claude-sonnet-4.5
# TRIAGE_MODEL=openrouter:anthropic/claude-haiku-4.5
# VERSION=0.1.0
# WHISPER_MODEL=whisper-1

